<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    version="5"
    map-background="#f0f0f0"
    map-background-outside="#EEEEEE"
>
    <rule e="way" k="highway" v="road">
        <line stroke="#bababa" stroke-width="1.2" />
    </rule>
    <rule e="way" k="highway" v="road" zoom-min="14">
        <pathText k="name" font-family="serif" font-style="bold" font-size="12" fill="#000000" stroke="#FFFFFF" stroke-width="0.9" />
    </rule>

    <rule e="way" k="highway" v="residential">
        <line stroke="#bababa" stroke-width="1.5" />
    </rule>
    <rule e="way" k="highway" v="residential" zoom-min="13">
        <pathText k="name" font-family="serif" font-style="bold" font-size="12" fill="#000000" stroke="#FFFFFF" stroke-width="1.1" />
    </rule>

    <rule e="way" k="highway" v="primary|secondary|ternary|unclassified">
        <line stroke="#adadad" stroke-width="3.0" />
    </rule>
    <rule e="way" k="highway" v="primary|secondary|ternary|unclassified" zoom-min="12">
        <pathText k="name" font-family="serif" font-style="bold" font-size="13" fill="#000000" stroke="#FFFFFF" stroke-width="1.6" />
    </rule>

    <rule e="way" k="highway" v="motorway|trunk">
        <line stroke="#9c9c9c" stroke-width="3.5" />
    </rule>
    <rule e="way" k="highway" v="motorway|trunk" zoom-min="10">
        <pathText k="name" font-family="serif" font-style="bold" font-size="14" fill="#000000" stroke="#FFFFFF" stroke-width="2.0" />
    </rule>

    <rule e="way" k="amenity" v="*">
        <area fill="#cccccc" />
    </rule>
    <rule e="way" k="building" v="*">
        <area fill="#cccccc" />
    </rule>

    <rule e="way" k="natural" v="water">
        <area fill="#8fcbff" />
    </rule>

    <rule e="any" k="natural" v="fell|grassland|tundra|wood|tree|tree_row">
        <area fill="#adfc9f" stroke="#122918" stroke-width="0.1"/>
    </rule>

    <rule e="any" k="leisure" v="*">
        <area fill="#adfc9f" stroke="#122918" stroke-width="0.1"/>
    </rule>
</rendertheme>