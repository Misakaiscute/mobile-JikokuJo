<?xml version="1.0" encoding="UTF-8"?>
<rendertheme
    xmlns="http://mapsforge.org/renderTheme"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    version="1">

    <!-- Roads - match by highway tag -->
    <rule e="way" k="highway" v="*">
        <line stroke="#E6E6E6" stroke-width="2" />
    </rule>

    <!-- Specific road types with different styles -->
    <rule e="way" k="highway" v="motorway|trunk">
        <line stroke="#FFA500" stroke-width="4" />
    </rule>

    <rule e="way" k="highway" v="primary">
        <line stroke="#FFC0CB" stroke-width="3" />
    </rule>

    <rule e="way" k="highway" v="secondary">
        <line stroke="#FFFF00" stroke-width="2.5" />
    </rule>

    <rule e="way" k="highway" v="residential|service|unclassified">
        <line stroke="#FFFFFF" stroke-width="2" />
    </rule>

    <!-- Buildings and areas -->
    <rule e="way" k="building" v="*" closed="yes">
        <area fill="#DDDDDD" stroke="#999999" stroke-width="0.3" />
    </rule>

    <!-- Parks -->
    <rule e="way" k="leisure" v="park" closed="yes">
        <area fill="#C8FACC" stroke="#006699" stroke-width="0.3" />
    </rule>

    <!-- Water -->
    <rule e="way" k="natural" v="water" closed="yes">
        <area fill="#B5D0D0" stroke="#6699CC" stroke-width="0.3" />
    </rule>
</rendertheme>